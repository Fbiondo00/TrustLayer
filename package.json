{
  "name": "trustlayer-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "web": "pnpm --filter @trustlayer/web dev",
    "mcp": "pnpm --filter @trustlayer/mcp-server dev",
    "cli": "pnpm --filter @trustlayer/cli dev",
    "fixtures": "pnpm --filter @trustlayer/core exec tsx src/__fixtures__/demo-verify.ts"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
